# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
#
# Load before starting the backend:
#   export $(grep -v '^#' .env | xargs) && ./mvnw spring-boot:run
#
# (On macOS you can also use `source .env` if the values don't contain spaces.)

# Anthropic API key for the "Analyze with AI" button on purchase lists.
# Get one at https://console.anthropic.com → Settings → API Keys.
# Requires credits on the account (pay-as-you-go, starts at $5).
ANTHROPIC_API_KEY=

# Optional — override the default model. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6
